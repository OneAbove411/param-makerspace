/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# The HTML entry point must NEVER be cached — it holds the versioned asset references.
# If the browser serves a stale index.html, it requests old JS/CSS chunks that no
# longer exist on the CDN after a redeploy, causing 404s and broken sessions.
/index.html
  Cache-Control: no-store, no-cache, must-revalidate

# JS and CSS chunks are content-hashed by Vite — cache them aggressively.
# When you redeploy, new hashes = new URLs = browser fetches fresh files.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Static files in /public (favicon, icons, _redirects, etc.)
/favicon.svg
  Cache-Control: public, max-age=86400

/icons.svg
  Cache-Control: public, max-age=86400
